pipeline {
    agent {
        docker {
            // This image is specifically maintained to have Maven, JDK 17, and the Docker CLI
            image 'ghcr.io/graalvm/jdk-community:17' 
            args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }
    stages {
        stage('Checkout') {
            steps {
                sh 'echo "Starting Pipeline for Build: ${BUILD_NUMBER}"'
            }
        }
        
        stage('Build and Test') {
            steps {
                sh 'cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && mvn clean package -DskipTests'
            }
        }
        
        stage('Static Code Analysis') {
            environment {
                SONAR_URL = "http://98.86.232.207:9000" 
            }
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    // Running with JDK 17 (from the docker agent) will now fix the ClassVersionError
                    sh '''
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app && \
                        mvn sonar:sonar \
                        -Dsonar.token=$SONAR_AUTH_TOKEN \
                        -Dsonar.host.url=${SONAR_URL}
                    '''
                }
            }
        }

       stage('Build and Push Docker Image') {
            steps {
                script {
                    sh '''
                        # Install docker cli if not present (Workaround for slim images)
                        if ! command -v docker &> /dev/null; then
                            apt-get update && apt-get install -y docker.io
                        fi
                        
                        cd java-maven-sonar-argocd-helm-k8s/spring-boot-app
                        docker build -t ${DOCKER_IMAGE} .
                    '''
                    
                    docker.withRegistry('https://index.docker.io/v1/', "docker-cred") {
                        docker.image("${DOCKER_IMAGE}").push()
                    }
                }
            }
        }
    }
}
        stage('Update Deployment File') {
            environment {
                GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
                GIT_USER_NAME = "SanthosVarahal" // Corrected spelling from your snippet if necessary
            }
            steps {
                withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                    sh '''
                        git config user.email "jenkins@cicd.com"
                        git config user.name "Jenkins Pipeline"
                        
                        # Use sed to update the image tag in the manifest
                        sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                        
                        git add java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests/deployment.yml
                        git commit -m "Update deployment image to version ${BUILD_NUMBER} [skip ci]"
                        git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                    '''
                }
            }
        }
    }
}
