pipeline {
    agent {
        docker {
            image 'maven:3.9.6-eclipse-temurin-17'
            args '--entrypoint="" --user root -v /var/run/docker.sock:/var/run/docker.sock'
        }
    }

    environment {
        DOCKER_IMAGE = "santhoshvarahal/ultimate-cicd:${BUILD_NUMBER}"
        SONAR_URL = "http://98.86.232.207:9000"
        GIT_REPO_NAME = "Jenkins-Zero-To-Hero"
        GIT_USER_NAME = "SanthosVarahal"
        GIT_EMAIL = "santoshvarahal@gmail.com"
        APP_DIR = "java-maven-sonar-argocd-helm-k8s/spring-boot-app"
        MANIFEST_DIR = "java-maven-sonar-argocd-helm-k8s/spring-boot-app-manifests"
    }

    options {
        timestamps()
        timeout(time: 1, unit: 'HOURS')
        buildDiscarder(logRotator(numToKeepStr: '10'))
    }

    stages {
        stage('Initialize') {
            steps {
                sh '''
                    set -e
                    echo "Installing Docker CLI..."
                    if ! command -v docker &> /dev/null; then
                        apt-get update && apt-get install -y docker.io
                    fi
                    docker --version
                '''
            }
        }

        stage('Build and Test') {
            steps {
                sh '''
                    set -e
                    cd ${APP_DIR}
                    echo "Building application..."
                    mvn clean package -DskipTests
                '''
            }
        }

        stage('Static Code Analysis') {
            steps {
                withCredentials([string(credentialsId: 'sonarqube', variable: 'SONAR_AUTH_TOKEN')]) {
                    sh '''
                        set -e
                        cd ${APP_DIR}
                        echo "Running SonarQube analysis..."
                        mvn sonar:sonar \
                            -Dsonar.token=${SONAR_AUTH_TOKEN} \
                            -Dsonar.host.url=${SONAR_URL} \
                            -Dsonar.projectKey=spring-boot-app || true
                    '''
                }
            }
        }

        stage('Build and Push Docker Image') {
            steps {
                sh '''
                    set -e
                    cd ${APP_DIR}
                    echo "Building Docker image: ${DOCKER_IMAGE}"
                    docker build -t ${DOCKER_IMAGE} .
                '''
                
                // Use credential helper instead of embedding token in URL
                withCredentials([usernamePassword(credentialsId: 'docker-cred', usernameVariable: 'DOCKER_USER', passwordVariable: 'DOCKER_PASS')]) {
                    sh '''
                        set -e
                        echo ${DOCKER_PASS} | docker login -u ${DOCKER_USER} --password-stdin
                        
                        echo "Pushing Docker image..."
                        docker push ${DOCKER_IMAGE} || (echo "Push failed, retrying..." && docker push ${DOCKER_IMAGE})
                        
                        docker logout
                    '''
                }
            }
        }

        stage('Update Deployment File') {
            steps {
                withCredentials([sshUserPrivateKey(credentialsId: 'github-ssh', keyVariable: 'SSH_KEY')]) {
                    sh '''
                        set -e
                        export GIT_SSH_COMMAND="ssh -i ${SSH_KEY} -o StrictHostKeyChecking=no"
                        
                        git config user.email "${GIT_EMAIL}"
                        git config user.name "${GIT_USER_NAME}"
                        
                        echo "Updating deployment manifest with build number: ${BUILD_NUMBER}"
                        sed -i "s/replaceImageTag/${BUILD_NUMBER}/g" ${MANIFEST_DIR}/deployment.yml
                        
                        git add ${MANIFEST_DIR}/deployment.yml
                        git commit -m "Update deployment image to version ${BUILD_NUMBER}" || true
                        git push origin main
                    '''
                }
            }
        }
    }

    post {
        always {
            sh '''
                set -e
                echo "Cleaning up Docker resources..."
                docker logout || true
                docker rmi ${DOCKER_IMAGE} || true
            '''
            cleanWs()
        }
        success {
            echo "Pipeline completed successfully! Image: ${DOCKER_IMAGE}"
        }
        failure {
            echo "Pipeline failed! Check logs above for details."
        }
    }
}
